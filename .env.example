# Banco de dados (Railway — plugin PostgreSQL do PROJETO DO SITE, separado do PEIx produto)
DATABASE_URL="postgresql://user:password@host:5432/peix_site"

# Resend
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="PEIx <contato@peix.ia.br>"

# Representante comercial (RF-LEAD-07)
REPRESENTANTE_EMAIL="comercial@peix.ia.br"

# Material informativo (RF-LEAD-06)
MATERIAL_INFORMATIVO_URL="https://peix.ia.br/materiais/decreto-12773.pdf"

# Cloudflare R2 (imagens de capa dos posts do blog)
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="peix-site-assets"
R2_ENDPOINT=""

# Sessão do painel admin (RF-ADMIN-01)
ADMIN_SESSION_SECRET="gerar-com: openssl rand -base64 32"
